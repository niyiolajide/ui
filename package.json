{
  "name": "@niyi/ui",
  "version": "0.11.2",
  "description": "Shared design system for the sibling apps: Tailwind preset, base CSS layers, and React primitives.",
  "license": "UNLICENSED",
  "repository": "github:niyiolajide/ui",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./tailwind-preset": "./tailwind-preset.js",
    "./eslint-config": "./eslint-config.js",
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "src",
    "styles.css",
    "tailwind-preset.js",
    "eslint-config.js"
  ],
  "scripts": {
    "lint": "eslint src scripts eslint-config.js eslint.config.mjs tailwind-preset.js --max-warnings=0",
    "build": "npm run lint && tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "test:usage": "npm run build && node scripts/test-usage-ingest-url.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "verify-dist": "npm run build && git diff --exit-code -- dist || (echo 'dist out of sync — run build and commit' && exit 1)",
    "test:tabs": "npm run build && node scripts/test-tabs-render.mjs",
    "test:sidebar": "npm run build && node scripts/test-sidebar-render.mjs",
    "test:rangeselector": "npm run build && node scripts/test-rangeselector-render.mjs"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0"
  },
  "peerDependencies": {
    "lucide-react": ">=0.300.0",
    "next": ">=14",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@niyi/platform": "github:niyiolajide/platform#d9aadb08592dc76e6e66cd031da7c5e37d6e3f1c",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "eslint": "^8.57.1",
    "lucide-react": "^0.323.0",
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.6.0"
  }
}
