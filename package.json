{
  "name": "@niyi/ui",
  "version": "0.1.0",
  "description": "Shared design system for the sibling apps: Tailwind preset, base CSS layers, and React primitives.",
  "license": "UNLICENSED",
  "repository": "github:niyiolajide/ui",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
    "./tailwind-preset": "./tailwind-preset.js",
    "./eslint-config": "./eslint-config.js",
    "./styles.css": "./styles.css"
  },
  "files": ["dist", "src", "styles.css", "tailwind-preset.js", "eslint-config.js"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/postbuild.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "verify-dist": "npm run build && git diff --exit-code -- dist || (echo 'dist out of sync — run build and commit' && exit 1)"
  },
  "dependencies": {
    "clsx": "^2.1.0",
    "tailwind-merge": "^2.5.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "lucide-react": ">=0.300.0",
    "next": ">=14"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "lucide-react": "^0.323.0",
    "next": "^14.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "typescript": "^5.6.0"
  }
}
